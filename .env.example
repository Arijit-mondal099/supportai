NEXT_PUBLIC_API_URI=http://localhost:3000

# Scalekit
SCALEKIT_ENVIRONMENT_URL=https://your-org.scalekit.dev
SCALEKIT_CLIENT_ID=skc_xxxxxxxxxxxxxxxx
SCALEKIT_CLIENT_SECRET=your_scalekit_client_secret

# MongoDB
